# ============================================
# Voice Agent Configuration
# Copy this file to .env and fill in your keys
# ============================================

# --- REQUIRED: Google AI (Gemini) ---
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# --- REQUIRED: Deepgram (Speech-to-Text) ---
# Get your key at: https://console.deepgram.com (free $200 credit)
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# --- REQUIRED: Telnyx (Phone Calls) ---
# Sign up at: https://telnyx.com
# Cost: ~$1.15/mo per phone number + $0.003/min
TELNYX_API_KEY=your-telnyx-api-key-here
TELNYX_SIP_URI=sip:your-number@sip.telnyx.com

# --- REQUIRED: Cloudflare R2 (Call Recordings) ---
# Set up at: https://dash.cloudflare.com → R2
# Free tier: 10 GB storage + 1M requests/month
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=voice-agent-voice-recordings
R2_PUBLIC_URL=https://your-bucket.r2.dev

# --- AI Models (defaults work great, no need to change) ---
LLM_MODEL=gemini-3-flash-preview
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# --- TTS (Text to Speech) ---
# Built-in voices: alba, marius, javert, jean, fantine, cosette, eponine, azelma
TTS_VOICE=alba

# --- Dashboard ---
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-random-string

# --- Database (default works fine, only change for production) ---
DB_PASSWORD=postgres

# --- LiveKit (auto-configured, no need to change) ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
